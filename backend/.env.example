# 后端环境变量示例（复制为 backend/.env 后按需修改）

# 生产环境必须设置 DJANGO_DEBUG=false，并配置强 SECRET_KEY、允许访问的域名和前端来源。
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000
DJANGO_CORS_ALLOW_ALL_ORIGINS=true

# 数据库连接。公开仓库仅提供占位符；实际值写入本地 backend/.env。
DB_NAME=dachuang_db
DB_USER=<local-db-user>
DB_PASSWORD=<local-db-password>
DB_HOST=localhost
DB_PORT=5432

# 生产 HTTPS 安全项。部署在反向代理后时，代理需传递 X-Forwarded-Proto=https。
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_SECURE_HSTS_SECONDS=31536000

# 上传/日志目录（不设置会默认写入 .local/backend 下）
# DJANGO_MEDIA_ROOT=/absolute/path/to/media
# DJANGO_LOG_DIR=/absolute/path/to/logs
# DJANGO_LOG_MAX_BYTES=10485760
# DJANGO_LOG_BACKUP_COUNT=5
# 上传资源限制（字节）；业务字段仍按各接口校验更细的格式与大小。
# DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
# DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=26214400
# DJANGO_DATA_UPLOAD_MAX_NUMBER_FILES=20
# DJANGO_DATA_UPLOAD_MAX_NUMBER_FIELDS=2000

# 默认密码（默认不设置；创建/重置密码接口需显式传参）
# 本地如需批量导入或默认重置密码，可在 backend/.env 中设置强临时密码。
# DEFAULT_USER_PASSWORD=<local-initial-password>
# DEFAULT_RESET_PASSWORD=<local-reset-password>

# 演示数据种子用户密码。共享演示或生产相似环境必须设置强临时密码。
# DEMO_USER_PASSWORD=<strong-demo-password>
# DACHUANG_LEVEL1_USER=<local-level1-user-id>
# DACHUANG_LEVEL2_USER=<local-level2-user-id>
# DACHUANG_TEACHER_USER=<local-teacher-user-id>
# DACHUANG_STUDENT_USER=<local-student-user-id>

# 启动模式：gunicorn（默认）或 runserver
# DJANGO_SERVER_MODE=runserver
